# =========================================================================
# Jarvis SaaS Environment Configuration
# 
# Copy this file to .env and fill in real values before running:
#   cp deployment/.env.example deployment/.env
#   nano deployment/.env
#
# Then run:
#   docker compose -f deployment/docker-compose.yml up -d
#
# Do NOT commit .env to version control (it contains secrets).
# =========================================================================

# =========================================================================
# DOMAINS (Required)
# =========================================================================
# These must match your DNS A records pointing at your VPS IP
# Example: If your VPS IP is 192.0.2.1, create these DNS records:
#   onyx.yourdomain.com    A  192.0.2.1
#   n8n.yourdomain.com     A  192.0.2.1
#   inbox.yourdomain.com   A  192.0.2.1

ONYX_DOMAIN=onyx.yourdomain.com
N8N_DOMAIN=n8n.yourdomain.com
INBOX_DOMAIN=inbox.yourdomain.com

# =========================================================================
# SECRETS (Required)
# 
# Generate these with:
#   openssl rand -hex 24      (for N8N_ENCRYPTION_KEY)
#   openssl rand -base64 32   (for ONYX_SECRET, INBOX_SECRET)
# =========================================================================

# n8n workflow encryption key (must be hex string, 24+ chars)
N8N_ENCRYPTION_KEY=replace_with_24_hex_chars_from_openssl

# Onyx session secret (must be base64, 32+ chars)
ONYX_SECRET=replace_with_base64_32_chars_from_openssl

# Inbox Zero session secret (must be base64, 32+ chars)
INBOX_SECRET=replace_with_base64_32_chars_from_openssl

# =========================================================================
# DATABASE PASSWORDS (Required)
# 
# Use strong passwords (12+ chars, mix of uppercase, lowercase, numbers, symbols)
# These are internal only (not exposed to the internet).
# =========================================================================

ONYX_DB_PASSWORD=your_strong_postgres_password_for_onyx
N8N_DB_PASSWORD=your_strong_postgres_password_for_n8n
INBOX_DB_PASSWORD=your_strong_postgres_password_for_inbox
ONYX_MINIO_PASSWORD=your_strong_minio_password

# =========================================================================
# ADMIN CREDENTIALS (Required)
#
# These are the first user accounts created when you first visit each service.
# Change the passwords immediately after logging in.
# =========================================================================

ADMIN_EMAIL=admin@yourdomain.com
N8N_DEFAULT_PASSWORD=change_me_on_first_login_to_n8n

# =========================================================================
# SMTP (Required for email notifications)
#
# Your service uses SMTP to send user invitations, password resets, and
# notifications. You can use any SMTP provider:
# 
# Gmail:
#   SMTP_SERVER=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USERNAME=your-email@gmail.com
#   SMTP_PASSWORD=<App Password, not your account password>
#   See: myaccount.google.com → Security → App passwords
#
# Brevo (free tier, 300/day):
#   Create account at brevo.com, get SMTP credentials from Settings
#
# Mailjet, SendGrid, AWS SES, etc. also work.
# =========================================================================

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your_app_password_not_account_password

# Email address that appears as "from" when sending notifications
SMTP_FROM_EMAIL=noreply@yourdomain.com

# =========================================================================
# TIMEZONE (Required)
#
# Used for scheduling reminders, showing local time in the chat, etc.
# Examples: Asia/Kolkata, America/New_York, Europe/London, UTC
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# =========================================================================

TIMEZONE=Asia/Kolkata

# =========================================================================
# GOOGLE OAUTH (Optional but recommended)
#
# Enables single sign-on (SSO) via Google for Onyx and Inbox Zero.
# This is optional — both services have basic email/password auth as fallback.
#
# Setup (takes 10 min):
#   1. Go to console.cloud.google.com
#   2. Create new project
#   3. Enable Google+ API
#   4. Create OAuth 2.0 Client ID (Web application)
#   5. Authorized redirect URIs:
#      - https://onyx.yourdomain.com/auth/callback
#      - https://inbox.yourdomain.com/auth/callback
#   6. Copy Client ID and Secret below
# =========================================================================

GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_or_leave_empty
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_secret_or_leave_empty

# =========================================================================
# OPENAI (Optional, for AI email drafting in Inbox Zero)
#
# If you want Inbox Zero to use GPT-4 for drafting emails and summarizing,
# add your OpenAI API key.
# Leave empty if not using (Inbox Zero still works with basic features).
#
# Get key at: platform.openai.com/api-keys
# =========================================================================

OPENAI_API_KEY=your_openai_api_key_or_leave_empty

# =========================================================================
# STRIPE (Optional, for future billing)
#
# If you plan to add paid plans, generate these at stripe.com/dashboard.
# For now, leave empty.
# =========================================================================

STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# =========================================================================
# Feature Flags (Advanced)
# =========================================================================

# Set to "false" to disable email connectors if you only want Gmail
ENABLE_EMAIL_CONNECTORS=true
